<%- include('partials/header') %>

    <main style="margin-top: 2rem;">
        <a href="/" class="btn-back">
            <span>← Back to Home</span>
        </a>
        <div class="filter-bar">
            <div class="filter-group">
                <input type="text" id="search-input" onkeyup="filterProducts()"
                    placeholder="Search products (brand, model...)" />
            </div>
            <div class="filter-group">
                <select id="category-select"
                    onchange="location.href = this.value === 'all' ? '/' : '/categories/' + this.value">
                    <option value="all" <%=typeof activeTab !=='undefined' && activeTab==='home' ? 'selected' : '' %>
                        >All Categories</option>
                    <% allCategories.forEach(cat=> { %>
                        <option value="<%= cat.slug %>" <%=typeof activeTab !=='undefined' && activeTab===cat.slug
                            ? 'selected' : '' %>>
                            <%= cat.title %>
                        </option>
                        <% }); %>
                </select>
            </div>
        </div>

        <h2 class="section-title">
            <%= category.title %>
        </h2>

        <% if (products.length===0) { %>
            <div style="text-align: center; padding: 4rem 1rem;">
                <p style="color: #94a3b8; font-size: 1.2rem;">No products found in this category.</p>
            </div>
            <% } else { %>
                <div class="products-grid">
                    <% products.forEach(prod=> { %>
                        <div class="product-card" data-title="<%= prod.title %>" data-brand="<%= prod.brand %>">
                            <a href="/products/<%= prod.slug %>" class="product-img-wrapper">
                                <img src="<%= prod.image %>" alt="<%= prod.title %>" class="product-card-img">
                            </a>
                            <div class="product-info">
                                <span class="product-brand">
                                    <%= prod.brand %>
                                </span>
                                <a href="/products/<%= prod.slug %>">
                                    <h3 class="product-title">
                                        <%= prod.title %>
                                    </h3>
                                </a>
                                <div class="product-meta">
                                    <span class="product-price">
                                        <%= prod.price.toLocaleString() %> ֏
                                    </span>
                                    <div class="product-rating">
                                        <span>★ <%= prod.rating %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } %>
    </main>

    <script>
        function filterProducts() {
            const searchVal = document.getElementById('search-input').value.toLowerCase().trim();
            const cards = document.querySelectorAll('.product-card');

            cards.forEach(card => {
                const title = card.getAttribute('data-title').toLowerCase();
                const brand = card.getAttribute('data-brand').toLowerCase();
                const matchesSearch = !searchVal || title.includes(searchVal) || brand.includes(searchVal);

                if (matchesSearch) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>